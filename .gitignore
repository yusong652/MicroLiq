# macOS system files
.DS_Store
**/.DS_Store

# Obsidian
.obsidian/

# Python
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

# IDE / tool config
.vscode/
.idea/
.toyoura-nagisa
.mcp.json

# Personal / private
career/

# Temporary files
*.tmp
*.temp
*~

# Word lock files
~$*

# Images (tracked separately or too large for git)
*.jpg
*.jpeg
*.png
*.svg

# Exception: demo images used by the website
!*/demo/*.png
!*/demo/*.jpg
!experiment/k0_effect.png
!site/assets/*.png
!site/assets/*.jpg

# Large media (managed by Git LFS)
*.gif
*.mp4
*.docx

# Paper figure PDFs (generated, not source)
papers/*/figures/*.pdf

# Build outputs
papers/*/build/
pdf_outputs/

# Data files
*.csv
