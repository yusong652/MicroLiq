# macOS system files
.DS_Store
**/.DS_Store

# Obsidian
.obsidian/

# Python
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

# IDE / tool config
.vscode/
.idea/
.toyoura-nagisa
.mcp.json
.claude/
.codex/

# Personal / private
career/

# Temporary files
*.tmp
*.temp
*~
shell_state.json
texput.log

# Word lock files
~$*

# Images (tracked separately or too large for git)
*.jpg
*.jpeg
*.png
*.svg

# Exception: demo images used by the website
!*/demo/*.png
!*/demo/*.jpg
!experiment/k0_effect.png
!site/assets/*.png
!site/assets/*.jpg

# Large media
*.gif
*.mp4
*.docx
*.blend
*.blend1

# Blender working directories (large renders and data)
*/blender-work/

# Paper figure PDFs (generated, not source)
papers/*/figures/*.pdf

# Paper reference PDFs
papers/*/ref/*.pdf

# Build outputs
papers/*/build/
pdf_outputs/

# Data files
*.csv

# YADE / PFC simulation state files (large, regenerable)
*.yade.gz
*.yade.bz2
*.yade
*.sav
post_generate*
post_consolidate*
post_shear*

# Docker compose (local paths hardcoded, not portable)
docker-compose.yml
docker-compose.override.yml

# MCP bridge runtime state
.yade-mcp/
.pfc-mcp/
